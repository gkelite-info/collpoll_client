### 1.4 Supabase RLS (Row Level Security)

```sql
-- Enable RLS
ALTER TABLE college_branding ENABLE ROW LEVEL SECURITY;

-- Policy: College admins can read their own college's branding
CREATE POLICY "college_branding_read_own"
ON college_branding
FOR SELECT
USING (
  "collegeId" IN (
    SELECT ca."collegeId"
    FROM college_admin ca
    WHERE ca."userId" = auth.uid()::integer
      AND ca.is_deleted = false
  )
  OR
  "collegeId" IN (
    SELECT a."collegeId"
    FROM admin a
    WHERE a."userId" = auth.uid()::integer
      AND a.is_deleted = false
  )
  OR
  "collegeId" IN (
    SELECT f."collegeId"
    FROM faculty f
    WHERE f."userId" = auth.uid()::integer
      AND f.is_deleted = false
  )
  OR
  "collegeId" IN (
    SELECT s."collegeId"
    FROM student s
    WHERE s."userId" = auth.uid()::integer
      AND s.is_deleted = false
  )
  OR
  "collegeId" IN (
    SELECT p."collegeId"
    FROM parent p
    WHERE p."userId" = auth.uid()::integer
      AND p.is_deleted = false
  )
);

-- Policy: Only super admins and college admins can update branding
CREATE POLICY "college_branding_update_own"
ON college_branding
FOR UPDATE
USING (
  "collegeId" IN (
    SELECT ca."collegeId"
    FROM college_admin ca
    WHERE ca."userId" = auth.uid()::integer
      AND ca.is_deleted = false
  )
);

-- Policy: Only super admins can insert (via service role or explicit policy)
CREATE POLICY "college_branding_insert_super_admin"
ON college_branding
FOR INSERT
WITH CHECK (
  EXISTS (
    SELECT 1 FROM super_admin sa
    WHERE sa."userId" = auth.uid()::integer
      AND sa.is_deleted = false
  )
);
```

